# node-defenders-frontend — environment variables
# Copy to .env.local for development

# NestJS API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Game + mode IDs — must match values in node-defenders-api
NEXT_PUBLIC_GAME_ID=1
NEXT_PUBLIC_SURVIVAL_MODE_ID=1

# Set to "true" to enable the beta dev console overlay
# Remove or set to anything else for production builds
NEXT_PUBLIC_DEV_MODE=true
